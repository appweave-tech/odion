# Credentials canonical location:
#   ~/work/appweave/ops-suite/apps/portal/.env.local  (Next.js shape)
#   ~/work/appweave/ai-delivery-hub/.env.local        (Python shape)
# Same Supabase project (appweave-ops), schema=odion for this app.

DATABASE_URL=postgresql://postgres.xxxxx:xxxxx@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# Schema isolation — every query in this app goes through schema=odion
DB_SCHEMA=odion

# Admin passcode for /admin — replace before deploy, rotate on host env.
# Use a 32+ char random string. Anything you set here is example-only.
ADMIN_PASSCODE=change-me-min-32-chars-rotate-on-host

# Optional: Twilio (v2)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
# TWILIO_WHATSAPP_GROUP=
