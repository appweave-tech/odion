# @opennextjs/cloudflare@1.x peer-depends on Next >= 15.5.18, but we're
# still on Next 14.2 and run the adapter with --dangerouslyUseUnsupportedNextVersion
# until the Next 15 upgrade lands. legacy-peer-deps keeps `npm install` /
# `npm clean-install` from failing under this mismatch (both locally and on
# CF Pages build agents). Remove this line once we're on Next 15+.
legacy-peer-deps=true
